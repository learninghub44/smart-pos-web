# ── Database ─────────────────────────────────────────────────────
# Neon Postgres connection string. Use the "pooled" connection string from
# the Neon dashboard (Connection Details → Pooled connection).
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Authentication ────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ── Payments ─────────────────────────────────────────────────────
# Paystack secret key (sk_live_... for production, sk_test_... for testing)
PAYSTACK_SECRET_KEY=sk_live_xxxxx

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=production
